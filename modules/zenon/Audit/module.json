{
  "name": "Audit",
  "alias": "audit",
  "description": "Field-change diffs and activity timeline on top of spatie/laravel-activitylog.",
  "providers": ["Modules\\Audit\\Providers\\AuditServiceProvider"],
  "zenon": {
    "id": "zenon/audit",
    "version": "1.0.0",
    "core": false,
    "requires": { "core": "^1.0" },
    "provides": ["audit.activity-log"],
    "hooks": { "emits": [] },
    "permissions": ["audit.activities.view"],
    "frontend": { "entry": "resources/js/index.ts", "remote": null },
    "platform": "^1.0",
    "defaultEnabled": true
  }
}
