{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "zenon/zenonerp",
    "type": "project",
    "description": "ZenonERP — modular, extensible ERP (multi-tenant SaaS + self-hosted standalone).",
    "keywords": ["erp", "laravel", "modular", "multi-tenant"],
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "composer/semver": "^3.4",
        "laravel/framework": "^13.8",
        "laravel/sanctum": "^4.3",
        "laravel/tinker": "^3.0",
        "nwidart/laravel-modules": "^13.0",
        "spatie/laravel-activitylog": "^4.12",
        "spatie/laravel-permission": "^8.3",
        "spatie/laravel-query-builder": "^7.0",
        "stancl/tenancy": "^3.10",
        "wikimedia/composer-merge-plugin": "^2.1"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "larastan/larastan": "^3.0",
        "laravel/pail": "^1.2.5",
        "laravel/pao": "^1.0.6",
        "laravel/pint": "^1.27",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Modules\\": "modules/zenon/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/",
            "Modules\\Dummy\\": "tests/Fixtures/modules/Dummy/app/",
            "Modules\\Dummy\\Database\\Seeders\\": "tests/Fixtures/modules/Dummy/database/seeders/",
            "Modules\\DummyDep\\": "tests/Fixtures/modules/DummyDep/app/",
            "Modules\\DummyCore\\": "tests/Fixtures/modules/DummyCore/app/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install --ignore-scripts",
            "npm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1 --timeout=0\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "test": [
            "@php artisan config:clear --ansi @no_additional_args",
            "@php artisan test"
        ],
        "lint": "@php vendor/bin/pint --test",
        "fix": "@php vendor/bin/pint",
        "analyse": "@php vendor/bin/phpstan analyse --memory-limit=1G",
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        },
        "merge-plugin": {
            "include": [
                "modules/zenon/*/composer.json",
                "modules/thirdparty/*/composer.json"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "wikimedia/composer-merge-plugin": true
        },
        "platform": {
            "php": "8.3.14"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
