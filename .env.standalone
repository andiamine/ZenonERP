APP_NAME=ZenonERP
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://app.zenonerp.test

# "saas" (default) = multi-tenant, subdomain per tenant. "standalone" = single tenant
# provisioned by the /install wizard (CLAUDE.md §7, Phase 8). App\Foundation\DeploymentMode
# is the single consumption point — fails closed to "saas" on anything unrecognized.
ZENON_MODE=standalone

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# Pin cache/queue rows to the CENTRAL DB (tenant isolation for cache comes from key
# prefixing via PrefixCacheTenancyBootstrapper; queue payloads carry tenant context).
DB_CACHE_CONNECTION=mysql
DB_QUEUE_CONNECTION=mysql

# Standalone mode only (config/database.php "standalone" connection, Phase 8) — pre-
# created tenant DB credentials for cPanel/Plesk hosts without CREATE DATABASE
# privilege. Filled in by the installer wizard; each falls back to the matching DB_*
# value above when left empty.
TENANT_DB_HOST=
TENANT_DB_PORT=
TENANT_DB_DATABASE=
TENANT_DB_USERNAME=
TENANT_DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Standalone has exactly one tenant on the installed host — blank means zero central
# routes registered (the installed host is the one tenant, CLAUDE.md §7).
TENANCY_CENTRAL_DOMAINS=

# Hosts that get Sanctum SPA cookie auth (config/sanctum.php defaults to these).
SANCTUM_STATEFUL_DOMAINS=app.zenonerp.test,*.zenonerp.test

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
