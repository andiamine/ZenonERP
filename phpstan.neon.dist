includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    level: 8
    paths:
        - app
        - modules/zenon
        - tests/Fixtures
    excludePaths:
        # Module Pest suites (CLAUDE.md §11: Larastan covers app/** + modules/zenon/**
        # PRODUCTION code) call global helpers defined in tests/Pest.php (createTenant,
        # installModule, statefulJson, …) — not statically visible to PHPStan, same
        # reason the root tests/ tree was never in `paths` above.
        - modules/zenon/*/tests/*
