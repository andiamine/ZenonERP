*.log
.DS_Store
.env
.env.backup
.env.production
.phpactor.json
.phpunit.result.cache
/.codex
/.cursor/
/.idea
/.nova
/.phpunit.cache
/.vscode
/.zed
/auth.json
/node_modules
# packages/** are plain local packages (file: deps, not an npm workspace) — each
# manages its own node_modules; root's anchored /node_modules above doesn't cover them.
packages/*/node_modules
# Third-party addons (modules/thirdparty/*) build their prebuilt remote with their own
# node_modules (file: dep on @zenon/module-kit) — never committed; the addon's dist/ IS
# committed (prebuilt Module Federation remote). The anchored /node_modules above only
# covers the repo root, so this nested rule is required.
modules/thirdparty/*/node_modules
/public/build
/public/fonts-manifest.dev.json
/public/hot
/public/storage
/storage/*.key
/storage/pail
/vendor
# composer.phar lives at bin/composer.phar (config('zenon.composer.phar_path'), Phase 8)
# for hosts with no system-wide Composer — never committed.
/bin/
# Derived boot artifact (CLAUDE.md §5) — mirrors the central `modules` table, regenerated
# by ModuleManager on install/uninstall; never hand-edited or committed.
/modules_statuses.json
_ide_helper.php
Homestead.json
Homestead.yaml
Thumbs.db
.remember/
/database/database.sqlite

# Local, user-specific — not shared
/CLAUDE.md
/.claude/
/database/zenon_tenant_*
/storage/framework/testing/
